---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLiveNotes } from '../../lib/content/notes';

const notes = await getLiveNotes();
---

<BaseLayout
  title="Notes · Fran Canete"
  description="Notes from Fran Canete on building software with coding agents, Claude Code, Pi agents, and practical AI-assisted development workflows."
>
  <main>
    <section id="notes" class="section-hero-personal notes-index-hero">
      <div class="container">
        <span class="hero-personal-role">02 / Notes · How I work with AI</span>

        <h1 class="page-title">
          How I build software with <em>coding agents.</em>
        </h1>

        <p class="hero-bio" style="max-width: 680px; margin: 0">
          Not a blog. A small set of notes on the practices, tools, and
          patterns I lean on when I'm building with AI in the loop. The stuff
          I'd rather write down once than keep explaining. Slow-moving by
          design.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="process-grid">
          <aside class="process-toc">
            <span class="process-toc-label">Contents</span>
            {notes.map((note, i) => (
              <a href={`/notes/${note.id}`}>
                <span class="label-text">
                  {String(i + 1).padStart(2, '0')} · {note.data.title.replace(/\.$/, '')}
                </span>
                <span class="pill live">Live</span>
              </a>
            ))}
          </aside>
          <div>
            {notes.map((note, i) => (
              <div id={`p-${i + 1}`} class="process-block">
                <div class="block-eyebrow">
                  <span class="num">
                    {String(i + 1).padStart(2, '0')} / {note.data.title.replace(/\.$/, '').toLowerCase()}
                  </span>
                  <span class="state live">Live</span>
                </div>
                <h2>{note.data.title}</h2>
                <p class="body-text">{note.data.description}</p>
                <div style="margin-top: 16px">
                  <a
                    href={`/notes/${note.id}`}
                    style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink); border-bottom: 1px solid var(--rule-2); padding-bottom: 2px;"
                  >
                    Read note →
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
