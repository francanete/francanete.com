---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { render } from 'astro:content';
import { getLiveNotes, readingTimeMinutes } from '../../lib/content/notes';

export async function getStaticPaths() {
  const notes = await getLiveNotes();
  return notes.map((note, index) => ({
    params: { slug: note.id },
    props: {
      note,
      prevNote: notes[index - 1] ?? null,
      nextNote: notes[index + 1] ?? null,
    },
  }));
}

const { note, prevNote, nextNote } = Astro.props;
const { Content } = await render(note);
const minutes = readingTimeMinutes(note.body);
const publishedLabel = note.data.publishedAt?.toLocaleDateString('en-GB', {
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={`${note.data.title} · Fran Canete`}
  description={note.data.description}
  type="article"
  publishedAt={note.data.publishedAt}
>
  <main id="main">
    <section class="section-hero-personal note-detail-hero">
      <div class="container">
        <div class="note-meta-top">
          <a href="/notes">← Notes</a>
          {publishedLabel && (
            <>
              <span class="sep">·</span>
              <span>{publishedLabel}</span>
            </>
          )}
          <span class="sep">·</span>
          <span>{minutes} min read</span>
        </div>

        <h1 class="page-title note-hero-title">{note.data.title}</h1>

        <p class="hero-bio note-hero-description">
          {note.data.description}
        </p>
      </div>
    </section>

    <section class="section note-detail-body">
      <div class="container" style="max-width: 720px">
        <article class="note-content">
          <Content />
        </article>

        <nav class="note-pager" aria-label="More notes">
          {prevNote ? (
            <a href={`/notes/${prevNote.id}`} class="pager-link prev">
              <span class="pager-label">← Previous</span>
              <span class="pager-title">{prevNote.data.title.replace(/\.$/, '')}</span>
            </a>
          ) : (
            <span />
          )}
          {nextNote ? (
            <a href={`/notes/${nextNote.id}`} class="pager-link next">
              <span class="pager-label">Next →</span>
              <span class="pager-title">{nextNote.data.title.replace(/\.$/, '')}</span>
            </a>
          ) : (
            <span />
          )}
        </nav>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .note-meta-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: 22px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .note-meta-top a {
    color: var(--ink);
    border-bottom: 1px solid var(--rule-2);
    padding-bottom: 1px;
    transition: border-color 0.15s;
  }
  .note-meta-top a:hover {
    border-color: var(--ink);
  }
  .note-meta-top .sep {
    color: var(--ink-4);
  }
  .note-pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--rule);
  }
  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .pager-link.next {
    text-align: right;
  }
  .pager-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .pager-title {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 1.3;
    color: var(--ink);
    transition: color 0.15s;
  }
  .pager-link:hover .pager-title {
    color: var(--accent);
  }
  @media (max-width: 640px) {
    .note-pager {
      grid-template-columns: 1fr;
    }
    .pager-link.next {
      text-align: left;
    }
  }
  .note-content :global(h2) {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 500;
    font-size: 28px;
    line-height: 1.15;
    letter-spacing: -0.018em;
    margin: 48px 0 16px;
    color: var(--ink);
  }
  .note-content :global(h3) {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 1.2;
    margin: 32px 0 12px;
    color: var(--ink);
  }
  .note-content :global(p) {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-2);
    margin: 0 0 18px;
  }
  .note-content :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }
  .note-content :global(em) {
    font-style: italic;
  }
  .note-content :global(a) {
    color: var(--ink);
    border-bottom: 1px solid var(--rule-2);
    padding-bottom: 1px;
    transition: border-color 0.15s;
  }
  .note-content :global(a:hover) {
    border-bottom-color: var(--accent);
    color: var(--accent);
  }
  .note-content :global(ul),
  .note-content :global(ol) {
    margin: 0 0 18px;
    padding-left: 24px;
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.7;
  }
  .note-content :global(li) {
    margin-bottom: 6px;
  }
  .note-content :global(code:not(pre code)) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13.5px;
    background: var(--chip-bg);
    padding: 1px 6px;
    border-radius: 4px;
  }
  .note-content :global([data-rehype-pretty-code-figure]) {
    margin: 0 0 18px;
  }
  .note-content :global([data-rehype-pretty-code-title]) {
    padding: 12px 16px 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .note-content :global([data-rehype-pretty-code-title] + pre) {
    margin-top: 8px;
  }
  .note-content :global(pre) {
    background: var(--code-bg);
    padding: 16px 20px;
    border: 1px solid var(--rule);
    border-radius: 8px;
    overflow-x: auto;
    margin: 0;
    font-size: 13.5px;
    line-height: 1.6;
  }
  .note-content :global(pre code) {
    background: transparent;
    padding: 0;
  }
  .note-content :global(pre code span) {
    color: var(--shiki-dark);
  }
  .note-content :global(pre code[data-line-numbers] > [data-line]::before) {
    counter-increment: line;
    content: counter(line);
    display: inline-block;
    width: 1.5rem;
    margin-right: 1rem;
    text-align: right;
    color: var(--ink-4);
  }
  .note-content :global(.note-panel) {
    margin: 0 0 28px;
    padding: 24px;
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: var(--accent-bg);
  }
  .note-content :global(.note-panel p:last-child) {
    margin-bottom: 0;
  }
  .note-content :global(.note-repo-card) {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    margin-top: 6px;
    padding: 14px 16px;
    border: 1px solid var(--rule);
    border-radius: 12px;
    background: var(--bg);
    color: var(--ink);
    transition: border-color 0.15s, transform 0.15s;
  }
  .note-content :global(.note-repo-card:hover) {
    border-color: var(--ink-4);
    transform: translateY(-1px);
  }
  .note-content :global(.note-repo-card svg) {
    width: 22px;
    height: 22px;
    flex: 0 0 auto;
    fill: currentColor;
  }
  .note-content :global(.note-repo-card span) {
    display: grid;
    gap: 2px;
  }
  .note-content :global(.note-repo-card strong) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 500;
  }
  .note-content :global(.note-repo-card small) {
    font-size: 13px;
    line-height: 1.4;
    color: var(--ink-3);
  }
  .note-content :global(.note-kicker) {
    display: block;
    margin-bottom: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .note-content :global(.note-meta-grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    margin: 28px 0 40px;
    overflow: hidden;
    border: 1px solid var(--rule);
    border-radius: 12px;
    background: var(--rule);
  }
  .note-content :global(.note-meta-grid > div) {
    padding: 18px;
    background: var(--bg);
  }
  .note-content :global(.note-meta-grid span) {
    display: block;
    margin-bottom: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .note-content :global(.note-meta-grid strong) {
    display: block;
    font-size: 14px;
    line-height: 1.35;
  }
  .note-content :global(.note-callout) {
    margin: 26px 0;
    padding: 16px 18px;
    border-left: 2px solid var(--ink);
    background: var(--accent-bg);
    border-radius: 0 8px 8px 0;
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.6;
  }
  .note-content :global(.note-code) {
    margin: 24px 0 30px;
    overflow: hidden;
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: var(--code-bg);
  }
  .note-content :global(.note-code-head) {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--code-rule);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--code-ink-2);
  }
  .note-content :global(.note-code-head code) {
    color: var(--code-ink-3);
    background: transparent;
    padding: 0;
    font-size: 11px;
    text-transform: none;
    letter-spacing: 0;
  }
  .note-content :global(.note-code pre) {
    margin: 0;
    padding: 18px;
    border-radius: 0;
    background: transparent;
    color: var(--code-ink);
  }
  .note-content :global(.note-code code) {
    color: inherit;
  }
  .note-content :global(.note-steps) {
    display: grid;
    gap: 12px;
    padding: 0;
    margin: 24px 0 30px;
    list-style: none;
  }
  .note-content :global(.note-steps li) {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px;
    padding: 18px 0;
    border-top: 1px solid var(--rule);
  }
  .note-content :global(.note-steps li:last-child) {
    border-bottom: 1px solid var(--rule);
  }
  .note-content :global(.note-steps li > span) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--ink-3);
  }
  .note-content :global(.note-steps div) {
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--ink-2);
  }
  .note-content :global(.note-chip-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 22px 0 24px;
  }
  .note-content :global(.note-chip-row span) {
    display: inline-flex;
    padding: 7px 10px;
    border-radius: 999px;
    background: var(--chip-bg);
    font-size: 12.5px;
    color: var(--ink-2);
  }
  @media (max-width: 640px) {
    .note-content :global(.note-meta-grid) {
      grid-template-columns: 1fr;
    }
    .note-content :global(.note-panel) {
      padding: 20px;
    }
  }
</style>
