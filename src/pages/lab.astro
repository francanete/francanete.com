---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../lib/data';

const displayStatus = (status: string, statusLabel?: string) =>
  statusLabel ?? (status === 'LIVE IN PRODUCTION' ? 'Live' : status.toLowerCase());
---

<BaseLayout
  title="Lab · Fran Canete"
  description="Product case studies from Fran Canete, including AI-enabled SaaS apps Plaudera and Duebase and the engineering lessons behind them."
>
  <main id="main">
    <section id="lab" class="section-hero-personal">
      <div class="container">
        <span class="hero-personal-role">03 / Lab · Product case studies</span>

        <h1 class="page-title">AI product systems, built <em>end to end.</em></h1>

        <div class="page-meta">
          <span class="kind">{String(projects.length).padStart(2, '0')} case studies</span>
          <span class="sep">·</span>
          <span>Independent product work</span>
          <span class="sep">·</span>
          <span>Updated Jul 2026</span>
        </div>

        <p class="hero-bio" style="max-width: 720px; margin: 0">
          Independent case studies built to demonstrate applied AI product
          engineering: model workflows, structured extraction, embeddings,
          human review, reliability controls, and the full-stack product systems
          that make those features useful in practice.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="lab-list">
          {projects.map((project, index) => {
            const liveUrl = project.links.liveUrl;
            const aiStack = new Set(project.aiSystem.stack);
            const platformStack = project.techStack.filter((technology) => !aiStack.has(technology));

            return (
              <article class="lab-case">
                <header class="lab-case-head">
                  <div class="left">
                    <span class="num">{String(index + 1).padStart(2, '0')}</span>
                    <h2>{project.title}.</h2>
                  </div>
                  <div class="right">
                    {liveUrl && (
                      <a href={liveUrl} target="_blank" rel="noopener noreferrer">
                        {new URL(liveUrl).hostname.replace('www.', '')} →
                      </a>
                    )}
                    <span class="sep">·</span>
                    <span>{project.category}</span>
                    <span class="sep">·</span>
                    <span class="status">{displayStatus(project.status, project.statusLabel)}</span>
                  </div>
                </header>
                <p class="lab-lead">{project.summary ?? project.description}</p>

                <div class="lab-outcome">
                  <span class="label">Product outcome</span>
                  <p>{project.aiSystem.outcome}</p>
                </div>

                <section class="lab-ai-system" aria-labelledby={`${project.id}-ai-system`}>
                  <div class="lab-section-label">
                    <span id={`${project.id}-ai-system`}>AI workflow</span>
                    <span class="count">{String(project.aiSystem.workflow.length).padStart(2, '0')} steps</span>
                  </div>
                  <ol class="lab-workflow">
                    {project.aiSystem.workflow.map((step, stepIndex) => (
                      <li>
                        <span class="n">{String(stepIndex + 1).padStart(2, '0')}</span>
                        <span>{step}</span>
                      </li>
                    ))}
                  </ol>
                </section>

                <div class="lab-ai-detail">
                  <section class="lab-evidence" aria-labelledby={`${project.id}-engineering`}>
                    <div class="lab-section-label">
                      <span id={`${project.id}-engineering`}>AI engineering</span>
                      <span class="count">Implementation</span>
                    </div>
                    <ul>
                      {project.aiSystem.engineering.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </section>
                  <section class="lab-evidence" aria-labelledby={`${project.id}-safeguards`}>
                    <div class="lab-section-label">
                      <span id={`${project.id}-safeguards`}>Reliability and guardrails</span>
                      <span class="count">Product judgement</span>
                    </div>
                    <ul>
                      {project.aiSystem.safeguards.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </section>
                </div>

                <div class="lab-stack-groups">
                  <div class="lab-stack-group lab-stack-ai">
                    <div class="lab-section-label">
                      <span>AI stack</span><span class="count">{project.aiSystem.stack.length} items</span>
                    </div>
                    <div class="chips">
                      {project.aiSystem.stack.map((technology) => (
                        <span class="chip chip-sm chip-dark">{technology}</span>
                      ))}
                    </div>
                  </div>
                  <div class="lab-stack-group">
                    <div class="lab-section-label">
                      <span>Platform stack</span><span class="count">{platformStack.length} items</span>
                    </div>
                    <div class="chips">
                      {platformStack.slice(0, 8).map((technology) => (
                        <span class="chip chip-sm">{technology}</span>
                      ))}
                      {platformStack.length > 8 && (
                        <span class="mono-text lab-stack-more">+{platformStack.length - 8}</span>
                      )}
                    </div>
                  </div>
                </div>

                <div class="lab-learned">
                  <span class="label">What I learned</span>
                  <ul>
                    {project.learned.map((lesson) => (
                      <li>{lesson}</li>
                    ))}
                  </ul>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
