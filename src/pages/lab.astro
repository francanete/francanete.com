---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../lib/data';

const projectMeta: Record<string, { launched: string; learned: string[] }> = {
  planitly: {
    launched: '2024',
    learned: [
      'Structured outputs (Zod schemas) changed everything. Free-text JSON is a debugging nightmare; schema-validated is night-and-day.',
      "Background jobs are non-negotiable for LLM workflows. Anything > 5s needs Inngest, a queue, or you'll fight Vercel timeouts forever.",
      "I over-engineered the database too early. Half those 16 models could've started as JSONB columns. Schema-shape your data after you know how it's queried.",
    ],
  },
  duebase: {
    launched: '2025',
    learned: [
      'Gemini 2.5 Flash with structured outputs is shockingly good at financial document parsing — and an order of magnitude cheaper than GPT-4o for this workload.',
      'Payment reconciliation is its own product. Two providers, three race conditions, one cron job. Worth getting right before you have paying users, not after.',
      "Trial systems live or die by lifecycle logic. The 14-day reset cost me a week of bugs that only production traffic could've surfaced.",
    ],
  },
};

const displayStatus = (status: string) =>
  status === 'LIVE IN PRODUCTION' ? 'Live' : status.toLowerCase();
---

<BaseLayout
  title="Lab · Fran Canete"
  description="Side-project case studies from Fran Canete, including production AI SaaS apps Planitly and Duebase and the engineering lessons behind them."
>
  <main>
    <section id="lab" class="section-hero-personal">
      <div class="container">
        <span class="hero-personal-role">03 / Lab · Side projects</span>

        <h1 class="page-title">What I built, what I <em>learned.</em></h1>

        <div class="page-meta">
          <span class="kind">{String(projects.length).padStart(2, '0')} case studies</span>
          <span class="sep">·</span>
          <span>Both live in production</span>
          <span class="sep">·</span>
          <span>Updated Apr 2026</span>
        </div>

        <p class="hero-bio" style="max-width: 720px; margin: 0">
          Two production AI SaaS apps and the lessons I'm still digesting.
          Each one taught me something I couldn't have picked up from a
          tutorial — about LLMs, about scale, about the gap between "it works"
          and "it ships." The "What I learned" sections matter more than the
          stack lists.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="lab-list">
          {projects.map((project, index) => {
            const meta = projectMeta[project.id];
            const liveUrl = project.links.liveUrl;

            return (
              <article class="lab-case">
                <header class="lab-case-head">
                  <div class="left">
                    <span class="num">{String(index + 1).padStart(2, '0')}</span>
                    <h2>{project.title}.</h2>
                  </div>
                  <div class="right">
                    {liveUrl && (
                      <a href={liveUrl} target="_blank" rel="noopener noreferrer">
                        {new URL(liveUrl).hostname.replace('www.', '')} →
                      </a>
                    )}
                    <span class="sep">·</span>
                    <span>Launched {meta.launched}</span>
                    <span class="sep">·</span>
                    <span class="status">{displayStatus(project.status)}</span>
                  </div>
                </header>
                <p class="lab-lead">{project.summary ?? project.description}</p>

                <div class="lab-detail">
                  <div class="highlights">
                    <span class="label">
                      <span>Highlights</span><span class="count">03 / many</span>
                    </span>
                    <ul>
                      {project.keyFeatures.slice(0, 3).map((feature, featureIndex) => (
                        <li>
                          <span class="n">{String(featureIndex + 1).padStart(2, '0')}</span>
                          <span>{feature}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="stack">
                    <span class="label">
                      <span>Stack</span><span class="count">{project.techStack.length} items</span>
                    </span>
                    <div class="chips">
                      {project.techStack.slice(0, 7).map((technology) => (
                        <span class="chip chip-sm">{technology}</span>
                      ))}
                      {project.techStack.length > 7 && (
                        <span class="mono-text" style="align-self: center; padding-left: 4px">
                          +{project.techStack.length - 7}
                        </span>
                      )}
                    </div>
                  </div>
                </div>

                <div class="lab-learned">
                  <span class="label">What I learned</span>
                  <ul>
                    {meta.learned.map((lesson) => (
                      <li>{lesson}</li>
                    ))}
                  </ul>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
