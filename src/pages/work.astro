---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import timworksLogo from '../assets/logos/hellotim_logo.jpeg';
import selfEmployedLogo from '../assets/logos/self-employed.png';
import bancoPopularLogo from '../assets/logos/bank-popular.jpeg';
import geMoneyLogo from '../assets/logos/ge-capital-bank.jpeg';
import connexaiLogo from '../assets/logos/connex_one_ltd_logo.jpeg';
---

<BaseLayout title="Work · Fran Canete">
  <main>
    <section id="work" class="section-hero-personal">
      <div class="container">
        <span class="hero-personal-role">01 / Work · Current role</span>

        <h1 class="page-title">
          Building integrations at <em>ConnexAI</em>.
        </h1>

        <div class="page-meta">
          <span class="kind">Full Stack Software Engineer</span>
          <span class="sep">·</span>
          <span>Manchester · Hybrid</span>
          <span class="sep">·</span>
          <span>Feb 2023 → now · 3y 3mo</span>
          <span class="sep">·</span>
          <span class="status">Now</span>
        </div>

        <p class="hero-bio" style="max-width: 680px; margin: 0 0 14px">
          I build third-party integrations that connect ConnexAI's
          contact-center platform to the tools enterprise teams already use.
          Most of my work lives at the seam where two systems were never
          designed to talk to each other — that's where the interesting bugs
          and the satisfying wins both live.
        </p>
        <p class="hero-bio" style="max-width: 680px; margin: 0">
          My focus has shifted over the last year toward AI-assisted
          development. I use Claude Code daily, and a lot of what I learn
          there ends up on
          <a
            href="/notes"
            style="color: var(--ink); border-bottom: 1px solid var(--rule-2); padding-bottom: 1px;"
            >/notes</a
          >.
        </p>
      </div>
    </section>

    <!-- Integrations shipped -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Integrations shipped</span>
          <span class="mono-text">04 total · 03 shipped · 01 in progress</span>
        </div>
        <ul class="work-list">
          <li>
            <div class="work-row">
              <span class="num">01</span>
              <div class="body">
                <h4>HubSpot Calling Widget</h4>
                <p>
                  Embedded calling UI inside HubSpot. Streamlined workflows
                  for sales teams using both platforms.
                </p>
              </div>
              <div class="status">
                <span class="year">2023</span>
                <span class="state shipped">Shipped</span>
              </div>
            </div>
          </li>
          <li>
            <div class="work-row">
              <span class="num">02</span>
              <div class="body">
                <h4>Azure Entra ID (SCIM)</h4>
                <p>
                  Automated user lifecycle: provisioning, de-provisioning,
                  group sync. Robust enough for enterprise tenants.
                </p>
              </div>
              <div class="status">
                <span class="year">2024</span>
                <span class="state shipped">Shipped</span>
              </div>
            </div>
          </li>
          <li>
            <div class="work-row">
              <span class="num">03</span>
              <div class="body">
                <h4>Jira</h4>
                <p>
                  Side-by-side ticket management embedded in the agent
                  workspace. No more tab-switching mid-call.
                </p>
              </div>
              <div class="status">
                <span class="year">2024</span>
                <span class="state shipped">Shipped</span>
              </div>
            </div>
          </li>
          <li>
            <div class="work-row">
              <span class="num">04</span>
              <div class="body">
                <h4>Microsoft Teams</h4>
                <p>
                  End-to-end integration for internal collaboration. Currently
                  in active development.
                </p>
              </div>
              <div class="status">
                <span class="year">2026</span>
                <span class="state progress">In progress</span>
              </div>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- Career timeline -->
    <section class="section">
      <div class="container">
        <div class="exp-rail">
          <div class="exp-rail-line"></div>

          <div class="exp-row">
            <div class="exp-date">2023 — <span class="exp-now">now</span></div>
            <div class="exp-node"><div class="exp-dot"></div></div>
            <div class="exp-content">
              <div class="exp-title-row">
                <Image src={connexaiLogo} alt="ConnexAI" class="exp-logo" width={36} height={36} loading="lazy" />
                <div>
                  <h3 class="h3-text" style="margin: 0">Full Stack Software Engineer</h3>
                  <p class="exp-meta">ConnexAI · Manchester, UK · Hybrid</p>
                </div>
              </div>
              <p class="body-sm" style="margin: 8px 0 0 50px">
                Building third-party integrations that connect ConnexAI's
                contact-center platform to the tools enterprise teams already
                use. See above for details.
              </p>
            </div>
          </div>

          <div class="exp-row">
            <div class="exp-date">2022 — 2023</div>
            <div class="exp-node"><div class="exp-dot"></div></div>
            <div class="exp-content">
              <div class="exp-title-row">
                <Image src={timworksLogo} alt="Timworks" class="exp-logo" width={36} height={36} loading="lazy" />
                <div>
                  <h3 class="h3-text" style="margin: 0">Software Engineer</h3>
                  <p class="exp-meta">Timworks · London, UK · Remote</p>
                </div>
              </div>
              <p class="body-sm" style="margin: 8px 0 0 50px">
                Contributing as a frontend engineer to build a web and mobile
                chat app that connects accountants with their customers.
              </p>
              <div class="exp-skills">
                <span class="chip chip-sm">React</span>
                <span class="chip chip-sm">TypeScript</span>
                <span class="chip chip-sm">React Native</span>
                <span class="chip chip-sm">Sass</span>
                <span class="mono-text" style="align-self: center; padding-left: 4px">+4</span>
              </div>
            </div>
          </div>

          <div class="exp-row">
            <div class="exp-date">2013 — 2021</div>
            <div class="exp-node"><div class="exp-dot"></div></div>
            <div class="exp-content">
              <div class="exp-title-row">
                <Image src={selfEmployedLogo} alt="Self-employed" class="exp-logo" width={36} height={36} loading="lazy" />
                <div>
                  <h3 class="h3-text" style="margin: 0">
                    Founder &amp; Business Consultant
                  </h3>
                  <p class="exp-meta">International Business · Remote</p>
                </div>
              </div>
              <p class="body-sm" style="margin: 8px 0 0 50px">
                Built a consulting practice from scratch serving 150+
                international business professionals with market research and
                trade data.
              </p>
              <div class="exp-skills">
                <span class="chip chip-sm">Business Strategy</span>
                <span class="chip chip-sm">Market Research</span>
                <span class="chip chip-sm">International Trade</span>
                <span class="chip chip-sm">Client Relations</span>
                <span class="mono-text" style="align-self: center; padding-left: 4px">+4</span>
              </div>
            </div>
          </div>

          <div class="exp-row">
            <div class="exp-date">2008 — 2009</div>
            <div class="exp-node"><div class="exp-dot"></div></div>
            <div class="exp-content">
              <div class="exp-title-row">
                <Image src={bancoPopularLogo} alt="Grupo Banco Popular" class="exp-logo" width={36} height={36} loading="lazy" />
                <div>
                  <h3 class="h3-text" style="margin: 0">Credit Risk Analyst</h3>
                  <p class="exp-meta">Grupo Banco Popular · Madrid, Spain · On-site</p>
                </div>
              </div>
              <p class="body-sm" style="margin: 8px 0 0 50px">
                Fundamental analysis of credit operations for individuals and
                companies. Identifying and evaluating financial risks and
                setting credit limits accordingly. Reporting and submitting
                operations to the Director of Investments and communicating
                with commercial branches.
              </p>
            </div>
          </div>

          <div class="exp-row">
            <div class="exp-date">2006 — 2008</div>
            <div class="exp-node"><div class="exp-dot"></div></div>
            <div class="exp-content">
              <div class="exp-title-row">
                <Image src={geMoneyLogo} alt="GE Money Bank" class="exp-logo" width={36} height={36} loading="lazy" />
                <div>
                  <h3 class="h3-text" style="margin: 0">Credit Risk Analyst</h3>
                  <p class="exp-meta">GE Money Bank · Madrid, Spain · On-site</p>
                </div>
              </div>
              <p class="body-sm" style="margin: 8px 0 0 50px">
                Fundamental analysis of credit operations for individuals and
                companies. Identifying and evaluating financial risks and
                setting credit limits accordingly. Reporting and submitting
                operations to the Director of Investments and communicating
                with commercial branches.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
