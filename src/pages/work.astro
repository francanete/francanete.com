---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { experiences } from '../lib/data';
import timworksLogo from '../assets/logos/hellotim_logo.jpeg';
import selfEmployedLogo from '../assets/logos/self-employed.png';
import bancoPopularLogo from '../assets/logos/bank-popular.jpeg';
import geMoneyLogo from '../assets/logos/ge-capital-bank.jpeg';
import connexaiLogo from '../assets/logos/connex_one_ltd_logo.jpeg';

const logoMap: Record<string, ImageMetadata> = {
  '/connex_one_ltd_logo.jpeg': connexaiLogo,
  '/hellotim_logo.jpeg': timworksLogo,
  '/self-employed.png': selfEmployedLogo,
  '/bank-popular.jpeg': bancoPopularLogo,
  '/ge-capital-bank.jpeg': geMoneyLogo,
};

const currentExperience = experiences.find((experience) => experience.isCurrent);
const integrationMeta = [
  { year: '2023', state: 'Shipped', className: 'shipped' },
  { year: '2024', state: 'Shipped', className: 'shipped' },
  { year: '2024', state: 'Shipped', className: 'shipped' },
  { year: '2026', state: 'In progress', className: 'progress' },
];
const integrations = currentExperience?.achievements.map((achievement, index) => ({
  ...achievement,
  ...integrationMeta[index],
})) ?? [];

const yearRange = (startDate: Date, endDate: Date | null) =>
  `${startDate.getFullYear()} — ${endDate ? endDate.getFullYear() : '<span class="exp-now">now</span>'}`;

const companyMeta = (experience: typeof experiences[number]) =>
  [experience.company, experience.location.replace(' Area', ''), experience.locationType]
    .filter(Boolean)
    .join(' · ');
---

<BaseLayout title="Work · Fran Canete">
  <main>
    <section id="work" class="section-hero-personal">
      <div class="container">
        <span class="hero-personal-role">01 / Work</span>

        <h1 class="page-title">
          Full-stack engineer. <em>AI products</em>, enterprise integrations.
        </h1>

        <p class="hero-bio" style="max-width: 680px; margin: 0 0 14px">
          I build end-to-end: from event-driven Inngest workflows and
          Sequelize models to multi-step React flows and Stripe webhooks.
          Side projects: Planitly and Duebase — both live in production.
        </p>
        <p class="hero-bio" style="max-width: 680px; margin: 0">
          Day job is enterprise integrations at ConnexAI — HubSpot, Azure
          SCIM, Jira, Teams. The career started in finance, which is why
          structured thinking shows up in everything I build.
        </p>
      </div>
    </section>

    <!-- Integrations shipped -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Integrations shipped</span>
          <span class="mono-text">04 total · 03 shipped · 01 in progress</span>
        </div>
        <ul class="work-list">
          {integrations.map((integration, index) => (
            <li>
              <div class="work-row">
                <span class="num">{String(index + 1).padStart(2, '0')}</span>
                <div class="body">
                  <h4>{integration.title}</h4>
                  <p>{integration.description}</p>
                </div>
                <div class="status">
                  <span class="year">{integration.year}</span>
                  <span class={`state ${integration.className}`}>{integration.state}</span>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Career timeline -->
    <section class="section">
      <div class="container">
        <div class="exp-rail">
          <div class="exp-rail-line"></div>

          {experiences.map((experience) => (
            <div class="exp-row">
              <div class="exp-date" set:html={yearRange(experience.startDate, experience.endDate)} />
              <div class="exp-node"><div class="exp-dot"></div></div>
              <div class="exp-content">
                <div class="exp-title-row">
                  <Image
                    src={logoMap[experience.companyLogo]}
                    alt={experience.company}
                    class="exp-logo"
                    width={36}
                    height={36}
                    loading="lazy"
                  />
                  <div>
                    <h3 class="h3-text" style="margin: 0">{experience.title}</h3>
                    <p class="exp-meta">{companyMeta(experience)}</p>
                  </div>
                </div>
                <p class="body-sm" style="margin: 8px 0 0 50px">
                  {experience.description}
                </p>
                {experience.skills.length > 0 && (
                  <div class="exp-skills">
                    {experience.skills.slice(0, 4).map((skill) => (
                      <span class="chip chip-sm">{skill}</span>
                    ))}
                    {experience.skills.length > 4 && (
                      <span class="mono-text" style="align-self: center; padding-left: 4px">
                        +{experience.skills.length - 4}
                      </span>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
