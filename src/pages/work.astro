---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { experiences } from '../lib/data';
import { logoMap } from '../lib/work/logos';

const currentExperience = experiences.find((experience) => experience.isCurrent);
const integrations = currentExperience?.achievements ?? [];

const companyMeta = (experience: (typeof experiences)[number]) =>
  [experience.company, experience.location.replace(' Area', ''), experience.locationType].join(' · ');
---

<BaseLayout
  title="Work · Fran Canete"
  description="Career and project work from Fran Canete, covering enterprise integrations, AI products, full-stack engineering, and production SaaS."
>
  <main id="main">
    <section id="work" class="section-hero-personal">
      <div class="container">
        <span class="hero-personal-role">01 / Work</span>

        <h1 class="page-title">
          Full-stack engineer. <em>AI products</em>, enterprise integrations.
        </h1>

        <p class="hero-bio work-hero-bio">
          I build enterprise-level integration solutions with full ownership
          from discovery to delivery. I understand the customer problem, design
          the technical solution, implement it, and make sure it works in
          production.
        </p>
        <p class="hero-bio work-hero-bio work-hero-bio-tight">
          My work is not just closing tickets — it is owning outcomes, solving
          real integration problems, and shipping reliable software for real
          users.
        </p>
      </div>
    </section>

    <!-- Integrations shipped -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Recent work</span>
        </div>
        <ul class="work-list">
          {integrations.map((integration, index) => (
            <li>
              <div class="work-row">
                <span class="num">{String(index + 1).padStart(2, '0')}</span>
                <div class="body">
                  <h4>{integration.title}</h4>
                  <p>{integration.description}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Career timeline -->
    <section class="section">
      <div class="container">
        <div class="exp-rail">
          <div class="exp-rail-line"></div>

          {experiences.map((experience) => (
            <div class="exp-row">
              <div class="exp-date">
                {experience.startDate.getFullYear()} —{' '}
                {experience.endDate ? experience.endDate.getFullYear() : <span class="exp-now">now</span>}
              </div>
              <div class="exp-node">
                <div class="exp-dot"></div>
                <Image
                  src={logoMap[experience.companyLogo]}
                  alt={experience.company}
                  class="exp-logo exp-node-logo"
                  width={28}
                  height={28}
                  loading="lazy"
                />
              </div>
              <div class="exp-content">
                <div class="exp-title-row">
                  <Image
                    src={logoMap[experience.companyLogo]}
                    alt={experience.company}
                    class="exp-logo exp-title-logo"
                    width={36}
                    height={36}
                    loading="lazy"
                  />
                  <div>
                    <h3 class="h3-text work-title">{experience.title}</h3>
                    <p class="exp-meta">{companyMeta(experience)}</p>
                  </div>
                </div>
                <p class="body-sm work-description">
                  {experience.description}
                </p>
                {experience.skills.length > 0 && (
                  <div class="exp-skills">
                    {experience.skills.slice(0, 4).map((skill) => (
                      <span class="chip chip-sm">{skill}</span>
                    ))}
                    {experience.skills.length > 4 && (
                      <span class="mono-text work-more-count">
                        +{experience.skills.length - 4}
                      </span>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .work-hero-bio {
    max-width: 720px;
    margin: 0 0 14px;
  }
  .work-hero-bio-tight {
    margin-bottom: 0;
  }
  .work-title {
    margin: 0;
  }
  .work-description {
    margin: 8px 0 0 50px;
  }
  .work-more-count {
    align-self: center;
    padding-left: 4px;
  }
  @media (max-width: 768px) {
    .work-description {
      margin: 10px 0 0;
      font-size: 14px;
    }
  }
</style>
