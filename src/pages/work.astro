---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { experiences } from '../lib/data';
import { logoMap } from '../lib/work/logos';

const currentExperience = experiences.find((experience) => experience.isCurrent);
const integrations = currentExperience?.achievements ?? [];

const companyMeta = (experience: (typeof experiences)[number]) =>
  [experience.company, experience.location.replace(' Area', ''), experience.locationType].join(' · ');
---

<BaseLayout
  title="Work · Fran Canete"
  description="Career work from Fran Canete, covering enterprise integrations, full-stack product engineering, workflow software, and AI-enabled SaaS proof."
>
  <main id="main">
    <section id="work" class="section-hero-personal">
      <div class="container">
        <span class="hero-personal-role">01 / Work</span>

        <h1 class="page-title">
          Enterprise integrations, workflow software, and <em>AI-enabled SaaS</em>.
        </h1>

        <p class="hero-bio work-hero-bio">
          My current professional proof is integration-heavy product work: turning
          customer workflow problems into reliable features across browser
          extensions, identity, ticketing, collaboration tools, and external APIs.
        </p>
        <p class="hero-bio work-hero-bio work-hero-bio-tight">
          The direction is deliberate: become the engineer who can understand the
          business process, design the implementation, ship the software, and use
          AI where it creates measurable leverage rather than noise.
        </p>
      </div>
    </section>

    <!-- Integrations shipped -->
    <section class="section" aria-labelledby="recent-integration-work-title">
      <div class="container">
        <div class="section-header">
          <h2 id="recent-integration-work-title" class="eyebrow work-section-title">
            Recent integration work
          </h2>
        </div>
        <ul class="work-list">
          {integrations.map((integration, index) => (
            <li>
              <div class="work-row">
                <span class="num">{String(index + 1).padStart(2, '0')}</span>
                <div class="body">
                  <h3>{integration.title}</h3>
                  <p>{integration.description}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Career timeline -->
    <section class="section" aria-labelledby="career-timeline-title">
      <div class="container">
        <div class="section-header">
          <h2 id="career-timeline-title" class="eyebrow work-section-title">Career timeline</h2>
        </div>
        <div class="exp-rail">
          <div class="exp-rail-line" aria-hidden="true"></div>

          <ol class="exp-list">
            {experiences.map((experience) => (
              <li class="exp-row">
                <div class="exp-date">
                  {experience.startDate.getFullYear()} —{' '}
                  {experience.endDate ? experience.endDate.getFullYear() : <span class="exp-now">now</span>}
                </div>
                <div class="exp-node">
                  <div class:list={['exp-dot', { current: experience.isCurrent }]} aria-hidden="true"></div>
                  <Image
                    src={logoMap[experience.companyLogo]}
                    alt=""
                    class="exp-logo exp-node-logo"
                    width={28}
                    height={28}
                    loading="lazy"
                  />
                </div>
                <div class="exp-content">
                  <div class="exp-title-row">
                    <Image
                      src={logoMap[experience.companyLogo]}
                      alt=""
                      class="exp-logo exp-title-logo"
                      width={36}
                      height={36}
                      loading="lazy"
                    />
                    <div>
                      <h3 class="h3-text work-title">{experience.title}</h3>
                      <p class="exp-meta">{companyMeta(experience)}</p>
                    </div>
                  </div>
                  <p class="body-sm work-description">
                    {experience.description}
                  </p>
                  {experience.skills.length > 0 && (
                    <div class="exp-skills">
                      {experience.skills.slice(0, 4).map((skill) => (
                        <span class="chip chip-sm">{skill}</span>
                      ))}
                      {experience.skills.length > 4 && (
                        <span
                          class="mono-text work-more-count"
                          aria-label={`${experience.skills.length - 4} more skills`}
                        >
                          +{experience.skills.length - 4} more
                        </span>
                      )}
                    </div>
                  )}
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .work-hero-bio {
    max-width: 720px;
    margin: 0 0 14px;
  }
  .work-hero-bio-tight {
    margin-bottom: 0;
  }
  .work-section-title,
  .exp-list {
    margin: 0;
    padding: 0;
  }
  .work-section-title {
    font-weight: 400;
  }
  .exp-list {
    list-style: none;
  }
  .work-title {
    margin: 0;
  }
  .work-description {
    margin: 8px 0 0 50px;
  }
  .work-more-count {
    align-self: center;
    padding-left: 4px;
  }
  @media (max-width: 768px) {
    .work-description {
      margin: 10px 0 0;
      font-size: 14px;
    }
  }
</style>
