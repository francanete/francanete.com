---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Fran Canete — Full Stack Engineer"
  description="Portfolio of Fran Canete, a Manchester-based full-stack engineer building AI products, enterprise integrations, and workflow systems."
>
  <main>
    <section id="home" class="section-hero-personal">
      <div class="container">
        <span class="hero-personal-role">Fran Canete</span>
        <div class="hero-personal-grid">
          <div class="hero-personal-text">
            <h1 class="page-title">
              AI products. Enterprise software.
              <em>Workflow systems that actually ship.</em>
            </h1>
            <p class="hero-lead">
              I build with a bias for outcomes, clarity, and leverage. I care
              about software that solves real problems and earns its place.
            </p>
            <div class="personal-links">
              <a href="https://github.com/francanete" target="_blank" rel="noopener noreferrer">GitHub</a><span class="sep">·</span>
              <a href="https://www.linkedin.com/in/francanete/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </div>
          </div>
          <aside class="hero-start-here">
            <div class="label">Start here</div>
            <ul class="picks">
              <li class="pick">
                <span class="kind">01 · Note</span>
                <a href="/notes/claude-code-workflow">My Claude Code setup →</a>
              </li>
              <li class="pick">
                <span class="kind">02 · Note</span>
                <a href="/notes/pi-agent-workflow">My Pi agent setup →</a>
              </li>
              <li class="pick">
                <span class="kind">03 · Note</span>
                <a href="/notes/keep-coding-agents-honest">How I keep coding agents honest →</a>
              </li>
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <!-- Now strip -->
    <section class="section-now-dark">
      <div class="container">
        <div class="now-strip-dark">
          <span class="now-label">Now</span>
          <span class="now-body"
            >Testing the Hermes agent; stitching it into a personal
            assistant workflow I'd actually use day to day.</span
          >
        </div>
      </div>
    </section>

    <!-- Pillars (indexed list) -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Three things I'm doing</span>
        </div>
        <ul class="pillar-list">
          <li>
            <a href="/work" class="pillar-row">
              <span class="num">01</span>
              <div class="body">
                <div class="title-row">
                  <span class="kind">Work</span>
                  <h3>Integrations at ConnexAI</h3>
                </div>
                <p>
                  HubSpot, Azure Entra, Jira, Teams. Building platform
                  connectors that thousands of enterprise users depend on
                  every day.
                </p>
              </div>
              <span class="date">Updated May 2026</span>
              <span class="arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/notes" class="pillar-row">
              <span class="num">02</span>
              <div class="body">
                <div class="title-row">
                  <span class="kind">Notes</span>
                  <h3>How I build with AI</h3>
                </div>
                <p>
                  Curated notes on the way I work with coding agents — how I
                  use Claude Code, the subagents I lean on, the hooks I run.
                  Written down so I don't have to repeat myself.
                </p>
              </div>
              <span class="date">Updated May 2026</span>
              <span class="arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/lab" class="pillar-row">
              <span class="num">03</span>
              <div class="body">
                <div class="title-row">
                  <span class="kind">Lab</span>
                  <h3>Side projects &amp; experiments</h3>
                </div>
                <p>
                  Planitly and Duebase — two production SaaS apps. What I
                  built, what broke, and what I'd do differently next time.
                </p>
              </div>
              <span class="date">Updated Apr 2026</span>
              <span class="arrow">→</span>
            </a>
          </li>
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>
