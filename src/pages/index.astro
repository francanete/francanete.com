---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Fran Canete — Full Stack Engineer">
  <main>
    <section id="home" class="section-hero-personal">
      <div class="container">
        <span class="hero-personal-role"
          >Self-taught Full Stack Engineer · Manchester, UK</span
        >
        <div class="hero-personal-grid">
          <div class="hero-personal-text">
            <p class="hero-lead">
              Full-stack engineer focused on AI-centric software and the
              engineering workflows around it. Currently at
              <strong>ConnexAI</strong> shipping enterprise SaaS features for
              global customers.
            </p>
            <p class="hero-bio">
              A decade running my own consulting business before transitioning
              to software. This site is a small, deliberate record: what I'm
              shipping at work, how I work with coding agents, and what I've
              built on the side. Curated, not a stream.
            </p>
            <div class="personal-links">
              <a href="https://github.com/francanete" target="_blank" rel="noopener noreferrer">GitHub</a><span class="sep">·</span>
              <a href="https://www.linkedin.com/in/francanete/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </div>
          </div>
          <aside class="hero-start-here">
            <div class="label">Start here</div>
            <ul class="picks">
              <li class="pick">
                <span class="kind">01 · Note</span>
                <a href="/notes/claude-code-workflow">How I use Claude Code →</a>
              </li>
              <li class="pick">
                <span class="kind">02 · Note</span>
                <a href="/notes/experiments-log">Experiments log →</a>
              </li>
              <li class="pick">
                <span class="kind">03 · Note</span>
                <a href="/notes/second-brain-with-obsidian">Second brain with Obsidian →</a>
              </li>
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <!-- Now strip -->
    <section class="section-now-dark">
      <div class="container">
        <div class="now-strip-dark">
          <span class="now-label">Now · Week of May 24</span>
          <span class="now-body"
            >Shipping the Microsoft Teams integration at ConnexAI;
            experimenting with Claude Code subagents for codebase
            exploration.</span
          >
          <span class="now-meta">Updated weekly</span>
        </div>
      </div>
    </section>

    <!-- Pillars (indexed list) -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Three things I'm doing</span>
        </div>
        <ul class="pillar-list">
          <li>
            <a href="/work" class="pillar-row">
              <span class="num">01</span>
              <div class="body">
                <div class="title-row">
                  <span class="kind">Work</span>
                  <h3>Integrations at ConnexAI</h3>
                </div>
                <p>
                  HubSpot, Azure Entra, Jira, Teams. Building platform
                  connectors that thousands of enterprise users depend on
                  every day.
                </p>
              </div>
              <span class="date">Updated May 2026</span>
              <span class="arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/notes" class="pillar-row">
              <span class="num">02</span>
              <div class="body">
                <div class="title-row">
                  <span class="kind">Notes</span>
                  <h3>How I build with AI</h3>
                </div>
                <p>
                  Curated notes on the way I work with coding agents — how I
                  use Claude Code, the subagents I lean on, the hooks I run.
                  Written down so I don't have to repeat myself.
                </p>
              </div>
              <span class="date">Updated May 2026</span>
              <span class="arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/lab" class="pillar-row">
              <span class="num">03</span>
              <div class="body">
                <div class="title-row">
                  <span class="kind">Lab</span>
                  <h3>Side projects &amp; experiments</h3>
                </div>
                <p>
                  Planitly and Duebase — two production SaaS apps. What I
                  built, what broke, and what I'd do differently next time.
                </p>
              </div>
              <span class="date">Updated Apr 2026</span>
              <span class="arrow">→</span>
            </a>
          </li>
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>
