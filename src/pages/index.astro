---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../lib/data';
import { getLiveNotes } from '../lib/content/notes';

const notes = await getLiveNotes();
const featuredNotes = notes.slice(0, 3);
const labProjectNames = projects.map((project) => project.title).join(' and ');
---

<BaseLayout
  title="Fran Canete — Full-Stack Product Engineer"
  description="Portfolio of Fran Canete, a Manchester-based full-stack product engineer building enterprise integrations, AI-enabled SaaS products, and workflow software."
>
  <main id="main">
    <section id="home" class="section-hero-personal">
      <div class="container">
        <div class="hero-personal-grid">
          <div class="hero-personal-text">
            <h1 class="page-title">
              Full-stack product engineer building <em>AI-enabled products</em>,
              enterprise integrations, and workflow software.
            </h1>
            <p class="hero-lead">
              I build product systems that combine practical engineering with AI
              where it creates real leverage: TypeScript, Node.js, React,
              PostgreSQL, APIs, background jobs, embeddings, structured outputs,
              and workflow design that turns messy inputs into usable software.
            </p>
            <div class="personal-links">
              <a href="https://github.com/francanete" target="_blank" rel="noopener noreferrer">GitHub</a><span class="sep">·</span>
              <a href="https://www.linkedin.com/in/francanete/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </div>
          </div>
          <aside class="hero-start-here">
            <div class="label">Start here</div>
            <ul class="picks">
              {featuredNotes.map((note, index) => (
                <li class="pick">
                  <span class="kind">{String(index + 1).padStart(2, '0')} · Note</span>
                  <a href={`/notes/${note.id}`}>{note.data.title.replace(/\.$/, '')} →</a>
                </li>
              ))}
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <!-- Now strip -->
    <section class="section-now-dark">
      <div class="container">
        <div class="now-strip-dark">
          <span class="now-label">Now</span>
          <span class="now-body"
            >Building enterprise integrations at ConnexAI while turning AI-enabled
            SaaS products into case studies for practical implementation work.</span
          >
        </div>
      </div>
    </section>

    <!-- Pillars (indexed list) -->
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Three things I'm doing</span>
        </div>
        <ul class="pillar-list">
          <li>
            <a href="/work" class="pillar-row">
              <span class="num">01</span>
              <div class="body">
                <div class="title-row">
                  <span class="kind">Work</span>
                  <h3>Integrations at ConnexAI</h3>
                </div>
                <p>
                  Chrome extension, Azure Entra, Jira, Teams. Building platform
                  connectors that turn customer workflow problems into reliable
                  product features.
                </p>
              </div>
              <span class="date">Updated May 2026</span>
              <span class="arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/notes" class="pillar-row">
              <span class="num">02</span>
              <div class="body">
                <div class="title-row">
                  <span class="kind">Notes</span>
                  <h3>How I build with AI</h3>
                </div>
                <p>
                  Practical notes on how I use coding agents without outsourcing
                  engineering judgement: setup, review loops, guardrails, and
                  the habits that keep AI-assisted work honest.
                </p>
              </div>
              <span class="date">Updated May 2026</span>
              <span class="arrow">→</span>
            </a>
          </li>
          <li>
            <a href="/lab" class="pillar-row">
              <span class="num">03</span>
              <div class="body">
                <div class="title-row">
                  <span class="kind">Lab</span>
                  <h3>Side projects</h3>
                </div>
                <p>
                  {labProjectNames} — production AI-enabled SaaS products where
                  the real work is product workflow design: async processing,
                  structured extraction, embeddings, similarity logic, review
                  loops, payments, auth, and guardrails that make AI features
                  usable in production.
                </p>
              </div>
              <span class="date">Updated Apr 2026</span>
              <span class="arrow">→</span>
            </a>
          </li>
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>
