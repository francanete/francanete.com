---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 · Fran Canete" description="Page not found.">
  <main id="main">
    <section class="section-hero-personal">
      <div class="container">
        <span class="hero-personal-role">404 / Not found</span>

        <h1 class="page-title">This page doesn't <em>exist.</em></h1>

        <p class="hero-bio" style="max-width: 560px; margin: 0">
          The link is broken or the page has moved. Try one of these instead.
        </p>

        <div class="personal-links">
          <a href="/">Home</a><span class="sep">·</span>
          <a href="/work">Work</a><span class="sep">·</span>
          <a href="/notes">Notes</a><span class="sep">·</span>
          <a href="/lab">Lab</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
