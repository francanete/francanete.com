---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Full-stack engineer focused on AI-centric software and the engineering workflows around it.',
} = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=5" />
    <link rel="icon" href="/favicon.ico?v=5" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Inter+Tight:wght@500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a href="/" class="topbar-brand">
          <span class="topbar-dot"></span> FRAN CANETE
        </a>
        <nav class="topbar-nav">
          <a
            href="/"
            class:list={[{ active: isActive('/') }]}
            aria-current={isActive('/') ? 'page' : undefined}
            >HOME</a
          >
          <a
            href="/work"
            class:list={[{ active: isActive('/work') }]}
            aria-current={isActive('/work') ? 'page' : undefined}
            >WORK</a
          >
          <a
            href="/notes"
            class:list={[{ active: isActive('/notes') }]}
            aria-current={isActive('/notes') ? 'page' : undefined}
            >NOTES</a
          >
          <a
            href="/lab"
            class:list={[{ active: isActive('/lab') }]}
            aria-current={isActive('/lab') ? 'page' : undefined}
            >LAB</a
          >
        </nav>
      </div>
    </header>
    <slot />

    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <span class="eyebrow">Get in touch</span>
            <p class="h2-text" style="margin: 20px 0 0; max-width: 320px">
              Reach out if you want to chat.
            </p>
          </div>
          <div class="mono-text">
            <a
              href="https://www.linkedin.com/in/francanete/"
              target="_blank"
              rel="noopener noreferrer"
              style="color: var(--ink)"
              >LINKEDIN →</a
            >
          </div>
          <div class="mono-text">
            <a
              href="https://github.com/francanete"
              target="_blank"
              rel="noopener noreferrer"
              style="color: var(--ink)"
              >GITHUB →</a
            >
          </div>
        </div>
        <div class="footer-bottom">
          <span class="mono-text">© 2026 Fran Canete</span>
        </div>
      </div>
    </footer>
  </body>
</html>
